---
import "@/styles/global.css";
import {
  certificates as Certificates,
  db,
  education as Education,
  eq,
  languages as Languages,
  personal_info as PersonalInfo,
  projects as Projects,
  skills as Skills,
  user_languages as UserLanguages,
  users as Users,
  experience as Experience,
} from "astro:db";
import { handleAdminUserPost } from "@/lib/admin";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { ENABLE_UPLOADS } from "@/lib/flags.ts";
import { buildAdminUserEditorViewModel, getAdminTabs } from "@/lib/view-models";
import { AdminUserEditor } from "@/components/react/admin";
import type { AdminTabId } from "@/types/view-models";

const userId = Number(Astro.params.id);
const [userRow] = await db.select().from(Users).where(eq(Users.id, userId));

// Fetch only the user row to verify existence
if (!userRow) {
  return Astro.redirect("/admin");
}

// Handle POST actions (create/update/delete)
let postError: { action: string; error?: string } | undefined;
// Capture current tab to preserve after successful POST
const redirectTab = Astro.url.searchParams.get("tab") || "basic";
if (Astro.request.method === "POST") {
  // Content-Length guard to avoid buffering huge requests
  const MAX_BODY = 6 * 1024 * 1024; // 6MB to account for multipart overhead (file max is 5MB)
  const clHeader = Astro.request.headers.get("content-length");
  const cl = clHeader ? Number(clHeader) : 0;
  if (Number.isFinite(cl) && cl > MAX_BODY) {
    // Route error to the most likely tab based on current ?tab

    const action =
      redirectTab === "projects" ? "upload_project_image" : "upload_user_image";
    postError = { action, error: "File too large (max 5MB)" };
  } else {
    const form = await Astro.request.formData();
    try {
      const result = await handleAdminUserPost(userId, form);
      if (result.error) {
        postError = result;
      } else {
        return Astro.redirect(`${Astro.url.pathname}?tab=${redirectTab}`);
      }
    } catch (e) {
      console.error(e);
      postError = {
        action: String(form.get("_action") || "unknown"),
        error: "An unexpected error occurred",
      };
    }
  }
}

// Get the active tab from URL search params or default to 'basic'
const activeTab = Astro.url.searchParams.get("tab") || "basic";
// Determine active tab based on post error if applicable
let errorTab = activeTab;

const tabActions = [
  { id: "basic", actions: ["update_user_basic"] },
  { id: "personal", actions: ["upsert_personal_info"] },
  { id: "image", actions: ["upload_user_image"] },
  { id: "education", actions: ["add_education", "update_education", "delete_education"] },
  { id: "experience", actions: ["add_experience", "update_experience", "delete_experience"] },
  { id: "certificates", actions: ["add_certificate", "update_certificate", "delete_certificate"] },
  {
    id: "projects",
    actions: ["add_project", "update_project", "delete_project", "upload_project_image"],
  },
  { id: "skills", actions: ["add_skill", "delete_skill"] },
  { id: "languages", actions: ["add_language", "delete_language"] },
];
const tabs = getAdminTabs(ENABLE_UPLOADS);

if (postError) {
  errorTab =
    tabActions.find((tab) => tab.actions.includes(postError.action))?.id || activeTab;
}
const finalTab = postError ? errorTab : activeTab;

const getError = (tabId: string) => {
  return postError && errorTab === tabId ? postError.error : undefined;
};

const [personalInfo] = await db
  .select()
  .from(PersonalInfo)
  .where(eq(PersonalInfo.user_id, userId));
const educationRows = await db
  .select()
  .from(Education)
  .where(eq(Education.user_id, userId));
const experienceRows = await db
  .select()
  .from(Experience)
  .where(eq(Experience.user_id, userId));
const certificateRows = await db
  .select()
  .from(Certificates)
  .where(eq(Certificates.user_id, userId));
const projectRows = await db
  .select()
  .from(Projects)
  .where(eq(Projects.user_id, userId));
const skillRows = await db
  .select()
  .from(Skills)
  .where(eq(Skills.user_id, userId));
const languageOptions = await db.select().from(Languages);
const userLanguageRows = await db
  .select()
  .from(UserLanguages)
  .where(eq(UserLanguages.user_id, userId));

const model = buildAdminUserEditorViewModel({
  userId,
  user: {
    id: userRow.id,
    firstName: userRow.first_name,
    lastName: userRow.last_name,
    email: userRow.email,
  },
  tabs,
  activeTab: finalTab as AdminTabId,
  errorByTab: {
    basic: getError("basic"),
    personal: getError("personal"),
    image: getError("image"),
    education: getError("education"),
    experience: getError("experience"),
    certificates: getError("certificates"),
    projects: getError("projects"),
    skills: getError("skills"),
    languages: getError("languages"),
  },
  enableUploads: ENABLE_UPLOADS,
  personalInfo: personalInfo
    ? {
        title: personalInfo.title,
        image: personalInfo.image,
        phone: personalInfo.phone,
        location: personalInfo.location,
        website: personalInfo.website,
        linkedin: personalInfo.linkedin,
        github: personalInfo.github,
        twitter: personalInfo.twitter,
        description: personalInfo.description,
      }
    : null,
  education: educationRows,
  experience: experienceRows,
  certificates: certificateRows,
  projects: projectRows,
  skills: skillRows.map((skill) => ({ id: skill.id, name: skill.name })),
  languageOptions: languageOptions.map((language) => ({
    id: language.id,
    language: language.language,
    abbr: language.abbr,
  })),
  userLanguages: userLanguageRows,
  editIds: {
    education: Number(Astro.url.searchParams.get("editEdu") || "") || undefined,
    experience: Number(Astro.url.searchParams.get("editExp") || "") || undefined,
    certificates: Number(Astro.url.searchParams.get("editCert") || "") || undefined,
    projects: Number(Astro.url.searchParams.get("editProj") || "") || undefined,
  },
});
---

<AdminLayout
  title={`${userRow.first_name} ${userRow.last_name} (${userRow.email})`}
>
  <AdminUserEditor model={model} client:load />
</AdminLayout>
