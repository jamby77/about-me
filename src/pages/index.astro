---
import { eq, experience, personal_info } from "astro:db";
import "@/styles/global.css";
import Layout from "@/layouts/Layout.astro";
import { db, users, projects, education, certificates, skills } from "astro:db";
import { buildPortfolioViewModel } from "@/lib/view-models";
import {
  PortfolioEducationSection,
  PortfolioProjectsSection,
  PortfolioSidebar,
  PortfolioSkillsSection,
} from "@/components/react/site";
import { PortfolioExperienceSection } from "@/components/react/site-experience";

const [
  userRows,
  infoRows,
  workRows,
  educationRows,
  certificateRows,
  projectRows,
  skillRows,
] = await Promise.all([
  db.select().from(users).where(eq(users.id, 1)),
  db.select().from(personal_info).limit(1),
  db.select().from(experience).where(eq(experience.user_id, 1)),
  db.select().from(education).where(eq(education.user_id, 1)),
  db.select().from(certificates).where(eq(certificates.user_id, 1)),
  db.select().from(projects).where(eq(projects.user_id, 1)),
  db.select().from(skills).where(eq(skills.user_id, 1)),
]);
const [user] = userRows;
const [info] = infoRows;

if (!user || !info) {
  return new Response("Portfolio data not set up yet.", { status: 404 });
}

const name = `${user.first_name} ${user.last_name}`;
const cv = buildPortfolioViewModel({
  basics: {
    name,
    title: info.title ?? "",
    image: info.image ?? "",
    email: user.email,
    phone: info.phone,
    location: info.location,
    website: info.website,
    linkedin: info.linkedin,
    github: info.github,
    twitter: info.twitter,
    description: info.description,
  },
  work: workRows,
  education: educationRows,
  certificates: certificateRows,
  projects: projectRows,
  skills: skillRows,
});
---

<Layout
  title={`${name} Portfolio - ${info.title}`}
  image={info.image}
  summary={info.description}
  url={info.website}
>
  <main
    class="relative grid max-w-7xl gap-12 p-8 max-sm:py-16 md:grid-cols-6 md:p-16 xl:gap-24 print:max-w-none print:grid-cols-1 print:gap-6"
  >
    <div
      class="space-y-6 md:col-span-2 print:col-span-1 print:grid print:grid-cols-2 print:gap-5 print:space-y-0"
    >
      <PortfolioSidebar basics={cv.basics} />
    </div>
    <div
      class="space-y-12 md:col-span-4 print:col-span-1 print:grid print:grid-cols-4 print:gap-2 print:space-y-0"
    >
      <PortfolioExperienceSection
        work={cv.work}
        className="print:col-span-3"
        client:load
      />
      <PortfolioProjectsSection projects={cv.projects} className="print:hidden" />
      <PortfolioSkillsSection skills={cv.skills} className="print:hidden" />
      <PortfolioEducationSection
        education={cv.education}
        certificates={cv.certificates}
        className="order-first"
      />
    </div>
    <div class="flex w-full max-w-7xl justify-center md:col-span-6 print:hidden">
    </div>
  </main>
</Layout>
<style>
  @page {
    size: auto;
    margin: 0;
  }
  main {
    margin: auto;
    width: 100%;
  }
</style>
