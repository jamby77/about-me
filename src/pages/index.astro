---
import { eq, experience, personal_info } from "astro:db";
import "@/styles/global.css";
import Layout from "@/layouts/Layout.astro";
import { db, users, projects, education, certificates, skills } from "astro:db";
import { buildPortfolioViewModel } from "@/lib/view-models";
import { PortfolioPage } from "@/components/react/site";

const [user] = await db.select().from(users).where(eq(users.id, 1));
const [info] = await db.select().from(personal_info).limit(1);
const workRows = await db.select().from(experience).where(eq(experience.user_id, 1));
const educationRows = await db.select().from(education).where(eq(education.user_id, 1));
const certificateRows = await db
  .select()
  .from(certificates)
  .where(eq(certificates.user_id, 1));
const projectRows = await db.select().from(projects).where(eq(projects.user_id, 1));
const skillRows = await db.select().from(skills).where(eq(skills.user_id, 1));

const name = `${user.first_name} ${user.last_name}`;
const cv = buildPortfolioViewModel({
  basics: {
    name,
    title: info.title ?? "",
    image: info.image ?? "",
    email: user.email,
    phone: info.phone,
    location: info.location,
    website: info.website,
    linkedin: info.linkedin,
    github: info.github,
    twitter: info.twitter,
    description: info.description,
  },
  work: workRows,
  education: educationRows,
  certificates: certificateRows,
  projects: projectRows,
  skills: skillRows,
});
---

<Layout
  title={`${name} Portfolio - ${info.title}`}
  image={info.image}
  summary={info.description}
  url={info.website}
>
  <PortfolioPage cv={cv} client:idle />
</Layout>
<style>
  @page {
    size: auto;
    margin: 0;
  }
  main {
    margin: auto;
    width: 100%;
  }
</style>
